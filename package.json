{
  "name": "magic-patterns-vite-template",
  "version": "0.0.1",
  "main": "electron-main.js",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npx vite",
    "build": "npx vite build",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "preview": "npx vite preview",
    "backup": "node backup-service.js",
    "electron-dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "dist": "npm run build && node build-dist.js",
    "package-win": "npm run build && electron-packager . MuthuwadigeHardwareERP --platform=win32 --arch=x64 --out=release-dist --overwrite --icon=build/icon.ico"
  },
  "dependencies": {
    "@emotion/react": "^11.13.3",
    "@supabase/supabase-js": "^2.98.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "0.522.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.4",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1",
    "xlsx": "^0.18.5",
    "xlsx-js-style": "^1.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.18",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^5.54.0",
    "@typescript-eslint/parser": "^5.54.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "latest",
    "concurrently": "^9.2.1",
    "electron": "^42.2.0",
    "electron-builder": "^25.1.8",
    "electron-is-dev": "^3.0.1",
    "electron-packager": "^17.1.2",
    "eslint": "^8.50.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.1",
    "postcss": "latest",
    "tailwindcss": "3.4.17",
    "typescript": "^5.5.4",
    "vite": "^5.2.0",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.muthuwadige.hardware",
    "productName": "Muthuwadige Hardware ERP",
    "asar": true,
    "files": [
      "dist/**/*",
      "package.json",
      "electron-main.js",
      "preload.js",
      "server.js",
      "backup-service.js",
      "hardware.db",
      "public/**/*",
      "build/**/*",
      ".env"
    ],
    "asarUnpack": [
      "resources/**/*",
      "dist/**/*"
    ],
    "directories": {
      "output": "release-dist"
    },
    "icon": "build/icon.ico",
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    }
  }
}
